# Frontend Environment Variables

# API Base URL (backend). For production: your backend Vercel URL (e.g. https://your-api.vercel.app)
VITE_API_URL=http://localhost:3001

# Google OAuth Client ID
# Get this from https://console.cloud.google.com/
# Create OAuth 2.0 Client ID → Web application
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Solana Configuration
# Use mainnet-beta for production, devnet for testing
VITE_SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
VITE_SOLANA_WS_ENDPOINT=wss://api.mainnet-beta.solana.com
